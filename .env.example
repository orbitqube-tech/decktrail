# DeckTrail portal environment. Copy to .env and fill in. Never commit .env.
# Generate the secrets with, for example: openssl rand -base64 32

# The ONLY value you must set. Everything below has a working default.
POSTGRES_PASSWORD=

# Leave these EMPTY. The portal generates them on first boot and persists them, so a fresh
# install needs no secrets configured.
#
# They must be empty, not a placeholder. The server fills a secret only when the variable is
# unset (server.ts, ensureBootSecrets), so any value here is the value it uses. A placeholder
# shipped in this file would be the live admin token of every install that copied it, and this
# file is public. Set one only if you have a real secret you want to pin.
DT_TOKEN_SECRET=
DT_SESSION_SECRET=
DT_ADMIN_TOKEN=
DT_BASE_HOST=localhost:3000
DT_COOKIE_SECURE=false
PORT=3000

# Email delivery for the magic link.
#
# Send through an authenticated mail service, NEVER from this app's own host. Mail sent
# from an application server's IP almost always fails SPF, DKIM, and DMARC (the three
# checks receivers use to trust a sender), so a strict inbox like Yahoo or Gmail files it
# as spam. Point the host below at your mailbox provider (for example smtp.hostinger.com,
# Google Workspace), or a transactional relay (Amazon SES, Resend, Mailgun) via its SMTP
# endpoint. Those services sign your mail and their IPs are authorised in your DNS, so it
# reaches the inbox. The From address must be a real mailbox on your sending domain.
#
# These may instead be set in the first-run setup wizard; an env value here overrides it.
# Leave them unset to log the magic link to the console instead of sending (fresh install).
DT_SMTP_HOST=
DT_SMTP_PORT=587
DT_SMTP_USER=
DT_SMTP_PASS=
DT_SMTP_FROM=no-reply@example.com

# Optional app-level DKIM signing. Only needed if you send DIRECT from a host whose mail
# service does not sign for you; a real mail service (above) already signs, so leave this
# unset there. To use it: generate a key (openssl genrsa -out dkim.key 2048), publish the
# public key in DNS at <selector>._domainkey.<domain>, and set the three values below.
# Prefer the key FILE (mounted secret) over the inline key so the secret stays off the env.
DT_DKIM_DOMAIN=
DT_DKIM_SELECTOR=
DT_DKIM_PRIVATE_KEY_FILE=
# DT_DKIM_PRIVATE_KEY=

# Abuse protection for the magic-link request form.
#
# Cloudflare Turnstile (a CAPTCHA alternative) verifies each request is human before a link
# is issued. Leave the secret unset to disable verification (fresh install / local dev). The
# sitekey is public and is served to the login form; the secret stays server-side. Get both
# from the Cloudflare dashboard (Turnstile). This stops automated abuse; the volumetric-DDoS
# layer is a Cloudflare edge rate-limit rule (see docs/DECISIONS.md and the runbook).
DT_TURNSTILE_SITEKEY=
DT_TURNSTILE_SECRET=

# Whether to believe the CF-Connecting-IP header.
#
# OFF by default, and leave it off unless the portal genuinely sits behind Cloudflare or
# another proxy that sets this header AND strips a client-supplied one. A header is written by
# whoever sends the request: trusted blindly, every per-IP limit below is bypassed by rotating
# it, and a caller can write any IP they like into your audit log. If your portal is reachable
# directly on its port, the socket address is the only thing that cannot be faked.
DT_TRUST_PROXY_HEADER=false

# Reverse proxy behind Traefik (only used by docker-compose.traefik.yml).
#
# Leave these untouched unless you serve DeckTrail behind Traefik instead of the bundled Caddy
# (see docs/guide/08-server-setup.md). They tell the overlay which Traefik to attach to; the
# defaults match the minimal Traefik in that guide. For an EXISTING Traefik, set TRAEFIK_NETWORK
# to the network it watches and the entrypoint/resolver to the names it defines.
TRAEFIK_NETWORK=proxy           # the external docker network your Traefik watches
TRAEFIK_ENTRYPOINT=websecure    # the Traefik entrypoint bound to 443
TRAEFIK_CERTRESOLVER=letsencrypt # the Traefik ACME certificate resolver to use

# App-level rate limiting on POST /auth/request, an origin-side backstop to the edge rule.
DT_RATELIMIT_IP_MAX=10          # max requests per IP per window
DT_RATELIMIT_IP_WINDOW_MS=60000 # the per-IP window, in milliseconds
DT_EMAIL_COOLDOWN_MS=60000      # minimum gap between links to one address (anti email-bombing)

# Engagement beacon ingest (POST /e) rate limit. Generous, to allow real slide navigation.
DT_RATELIMIT_EVENT_MAX=600      # max beacon events per IP per window
DT_RATELIMIT_EVENT_WINDOW_MS=60000

# Owner console. The React console is built into the image and served at /admin
# automatically. Set this only to serve a console build from a non-default location.
# DT_CONSOLE_DIR=

# Anonymous usage telemetry. OFF unless you opt in at first-run setup. When on, an opted-in
# instance sends only an anonymous instance id, the version, and bucketed counts (how many
# decks, roughly how many views) on a weekly schedule. It never sends your content, your
# clients, your viewers, or any exact figure, and it fails silently. Turn it off any time by
# setting telemetry_optin to false. These knobs only change where and how often it reports.
DT_TELEMETRY_ENDPOINT=https://decktrail.com/telemetry
DT_TELEMETRY_INTERVAL_MS=604800000   # weekly
