{
  "name": "@decktrail/renderers",
  "version": "0.0.0",
  "private": true,
  "description": "DeckTrail renderers: turn the deck IR plus a theme into HTML (standalone and portal).",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@decktrail/ir": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1"
  }
}
